{
  "name": "blastradius",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Claude Code observability. Phase 1: log-touch hook. Phase 2: live heat-map dashboard.",
  "main": "src/hook/log-touch.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "hook": "node src/hook/log-touch.js",
