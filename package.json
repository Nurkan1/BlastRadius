    "dev": "node --watch src/server/index.js"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ignore": "^6.0.2",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
