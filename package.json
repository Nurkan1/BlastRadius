{
  "name": "blastradius",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "Claude Code observability. Phase 1: log-touch hook. Phase 2: live heat-map dashboard. Phase 3: reverse-import impact propagation.",
  "main": "src/hook/log-touch.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "hook": "node src/hook/log-touch.js",
    "start": "node src/server/index.js",
    "dev": "node --no-warnings --watch src/server/index.js"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "dependency-cruiser": "^17.4.2",
    "diff2html": "^3.4.56",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "ignore": "^6.0.2",
    "pino": "^9.5.0",
    "simple-git": "^3.36.0",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
