# Dependencies
node_modules/

# Local environment (the example template is committed; the real .env is not)
.env
.env.local
.env.*.local

# Generated log output — BLASTRADIUS_LOG_DIR may point here in dev
logs/
*.jsonl

# Editor / OS noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Per-machine Claude Code config — contains absolute paths.
.claude/settings.json
.claude/settings.local.json
# Timestamped backups left behind by scripts/install-hook.ps1 when it
# rewrites settings.json idempotently. Pure per-machine history.
.claude/settings.json.bak.*

# Per-machine Antigravity plugin install (regenerated idempotently by
# scripts/install-hook.ps1 -Agent antigravity). Lives here when the
# user observes THIS repo with itself; nothing to version.
.agents/

# Per-machine BlastRadius marker / state file written by the runtime
# when the dashboard is launched against this repo.
.blastradius

# Vitest / coverage artifacts
coverage/
.vitest-cache/

# Build output (none yet, but reserved)
dist/

# Tauri build artifacts
src-tauri/target/
src-tauri/gen/

# Bundled Node.js binary for the Tauri sidecar. Pinned by
# scripts/prepare-bundle.bat, downloaded fresh on each clone or CI run.
# Out of git both because it's a ~50 MB binary and because we want the
# version pin to live in one place (the script). Lives at the repo
# root (NOT src-tauri/binaries) because Tauri 2 only reliably bundles
# resources reached via "../" from src-tauri/.
binaries/
