# BlastRadius environment

# ─── Phase 1 (log-touch hook) ────────────────────────────────────────────────

# Directory where the hook writes daily JSONL logs (session-YYYY-MM-DD.jsonl).
# Required for both the hook and the server. The hook exits silently when
# unset; the server refuses to boot when unset.
BLASTRADIUS_LOG_DIR=C:/Users/TrendingPC/Documents/BlastRadius/logs

# ─── Phase 2 (dashboard server) ──────────────────────────────────────────────

# Phase 5: parent directory containing the repos you want to observe.
# BlastRadius scans depth ≤3 for `.git/` markers and ranks repos by
# recent activity. Set this once via `.env` OR via the first-run wizard
# in the dashboard; the choice is then persisted to
# ~/.blastradius/preferences.json and the env var becomes optional.
BLASTRADIUS_PARENT_DIR=C:/Users/TrendingPC/Documents

# (Deprecated, kept for backward compatibility) Single-repo path. If
# this is set and BLASTRADIUS_PARENT_DIR is not, on first boot BlastRadius
# derives parentDir = dirname(TARGET_REPO), pins currentRepo = TARGET_REPO,
# and turns autoSwitch off. After that the preferences file is the source
# of truth and this variable is ignored. Migrate to BLASTRADIUS_PARENT_DIR
# at your convenience.
# BLASTRADIUS_TARGET_REPO=C:/projects/digitalrose

# HTTP port for the dashboard. Defaults to 7842 when unset.
BLASTRADIUS_PORT=7842

# Optional: pino log level for the server (trace|debug|info|warn|error).
BLASTRADIUS_LOG_LEVEL=info

# ─── Phase 3 (impact propagation) ────────────────────────────────────────────

# How many levels of reverse-import indirection to mark as YELLOW when a
# red file is detected. 1 = direct importers only, 2 = importers of
# importers, 3 = three hops. Clamped to [1, 3]. Default 2.
BLASTRADIUS_DEPTH=2
