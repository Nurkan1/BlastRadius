# BlastRadius — Phase 1 environment

# Directory where the daily JSONL logs live. The hook rotates files as
# session-YYYY-MM-DD.jsonl inside this directory. REQUIRED — if unset,
# the hook exits silently (still 0) without writing anything.
BLASTRADIUS_LOG_DIR=C:/Users/TrendingPC/Documents/BlastRadius/logs

# The repo this hook is observing. NOT consumed by the hook at runtime —
# the real cwd arrives in each PostToolUse stdin JSON payload from Claude
# Code. Kept here for operator diagnostics and for tooling that wraps
# install-hook.ps1.
BLASTRADIUS_TARGET_REPO=
