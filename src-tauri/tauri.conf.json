{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BlastRadius",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../src/public",
    "devUrl": "http://localhost:7842",
    "beforeDevCommand": "node src/server/index.js",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "BlastRadius",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
