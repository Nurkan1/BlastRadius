{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BlastRadius",
  "version": "1.0.0-rc9.0",
  "identifier": "com.blastradius.app",
  "build": {
    "frontendDist": "http://localhost:7842",
    "devUrl": "http://localhost:7842",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BlastRadius",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../src/**/*",
      "../node_modules/**/*",
      "../package.json",
      "../binaries/node.exe",
      "../bin/blastradius-mcp.mjs",
      "../bin/blastradius-mcp.cjs",
      "../scripts/install-hook.ps1",
      "../scripts/register-mcp.mjs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "wix": {
        "version": "1.0.0.15"
      }
    }
  }
}
